            "date": 1776190951274,
            "name": "Commit-0",
            "content": "export default function Footer({ onNavigate }) {\n  return (\n    <footer className=\"bg-slate-900 text-gray-400 mt-auto\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12\">\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8\">\n          {/* Brand */}\n          <div>\n            <h3 className=\"text-2xl font-extrabold text-white tracking-[0.2em] mb-3\">ARCA</h3>\n            <p className=\"text-sm leading-relaxed max-w-xs\">\n              Premium workspace accessories for those who care about every detail. Built for\n              creators, optimised for flow.\n            </p>\n          </div>\n\n          {/* Navigation */}\n          <div>\n            <h4 className=\"text-white font-semibold mb-4 text-xs tracking-widest uppercase\">\n              Navigate\n            </h4>\n            <ul className=\"space-y-2\">\n              {[\n                ['Home', 'home'],\n                ['Products', 'products'],\n                ['Cart', 'cart'],\n              ].map(([label, page]) => (\n                <li key={page}>\n                  <button\n                    onClick={() => onNavigate(page)}\n                    className=\"text-sm hover:text-white transition-colors duration-200 focus:outline-none\"\n                  >\n                    {label}\n                  </button>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* Support */}\n          <div>\n            <h4 className=\"text-white font-semibold mb-4 text-xs tracking-widest uppercase\">\n              Support\n            </h4>\n            <ul className=\"space-y-2 text-sm\">\n              <li>Free shipping on orders over $99</li>\n              <li>30-day free returns</li>\n              <li>2-year warranty on all products</li>\n              <li className=\"hover:text-white transition-colors duration-200\">\n                hello@arcastore.com\n              </li>\n            </ul>\n          </div>\n        </div>\n\n        <div className=\"border-t border-slate-800 mt-10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs\">\n          <p>© 2025 Arca Store. All rights reserved.</p>\n          <p>Built with React + Tailwind CSS</p>\n        </div>\n      </div>\n    </footer>\n  );\n}\n"
        }
    ]
